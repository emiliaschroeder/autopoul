---
// Henter parametrene fra Astro.props
const {
  href = "#",
  target = "_self",
  variant = "cta",
  color = "black",
} = Astro.props;

const colorClasses = {
  primary: "text-primary",
  black: "text-black",
  accent: "text-accent",
};

const variantClasses = {
  cta: "text-[40px] hover:text-[50px] font-sans uppercase underline md:text-[60px] hover:font-script md:hover:leading-[65px] md:hover:text-[80px]",
  nav: "text-[14px] hover:text-[16px] font-sans uppercase md:text-[24px] hover:font-script md:hover:text-[27px] md:hover:leading-7",
};
---

<!--Sæt classes for den pågældende knap sammen ved hjælp af Astros class:list -->
<a
  href={href}
  target={target}
  class:list={[variantClasses[variant], colorClasses[color]]}><slot /></a
>
