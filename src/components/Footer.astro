---
import Link from "./Link.astro";
---

<footer class="footer">
  <div
    class="absolute inset-0 pointer-events-none overflow-hidden"
    aria-hidden="true"
  >
    <img
      src="/img/singlechair.webp"
      alt=""
      class="absolute w-27 md:w-35 left: 20%; md:left-[75%] float-img"
      style="animation: floatDown 12s linear infinite -3s;"
    />
    <img
      src="/img/chairstack.webp"
      alt=""
      class="absolute w-48 md:w-65 left-[30%] md:left-[15%] float-img z-10"
      style="animation: floatDown 14s linear infinite -10s;"
    />
    <!-- Sætter z-index på her, for at få chairstack til at ligge øverst -->
    <img
      src="/img/table_outside.webp"
      alt=""
      class="absolute w-49 md:w-60 float-img left-0 md:left-[7%] z-0"
      style="animation: floatDown 17s linear infinite -6s;"
    />
    <img
      src="/img/outside.webp"
      alt=""
      class="absolute w-42 md:w-55 left-[61%] md:left-[50%] float-img"
      style="animation: floatDown 15s linear infinite -8s;"
    />
    <img
      src="/img/wine_inside.webp"
      alt=""
      class="absolute w-35 md:w-60 left-[70%] md:left-[85%] float-img"
      style="animation: floatDown 20s linear infinite -4s;"
    />
  </div>
  <!-- Billeder slut -->

  <!-- Nav + logo wrapper - sidder i bunden via flex-end på footer -->
  <div
    class="relative z-10 flex flex-col items-start
      gap-[var(--space-mob-xs)]
      px-[var(--space-mob-sm)]
      pb-[var(--space-mob-sm)]
      md:flex-row
      md:items-end
      md:justify-between
      md:px-[var(--space-desk-sm)]
      md:pb-[var(--space-desk-xs)]"
  >
    <!-- Nav links (her er der spacing på 203, som ikke er en fast spacing!) -->
    <nav
      class="flex flex-col
        gap-[var(--space-mob-xs)]
        md:flex-row
        md:gap-[203px]"
    >
      <Link href="/contact" variant="nav">CONTACT</Link>
      <Link href="/calendar" variant="nav">CALENDER</Link>
      <Link href="https://www.instagram.com/autopoul/" variant="nav"
        >INSTAGRAM</Link
      >
      <Link href="https://maps.app.goo.gl/cLvi5Whz5mzd6AHS6" variant="nav"
        >FIND US</Link
      >
    </nav>

    <!-- Logo -->
    <a
      href="/"
      aria-label="Gå til forsiden"
      class="inline-flex mt-[var(--space-mob-xxs)] md:mt-0"
    >
      <img src="/img/footer_logo.svg" alt="Autopoul" class="w-28 md:w-40" />
    </a>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    background-color: var(--color-primary);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;

    /* her skal vi lige kigge på scaffolding */
    height: 932px;
    min-height: 932px;
  }

  /* og her */
  @media (min-width: 768px) {
    .footer {
      height: max(846px, 100svh);
      min-height: 846px;
    }
  }

  /* evt. skal det her sættes i tailwindcss */
  @keyframes floatDown {
    0% {
      transform: translateY(-300px);
      opacity: 0;
    }
    5% {
      opacity: 1;
    }
    100% {
      transform: translateY(932px);
      opacity: 1;
    }
  }

  .float-img {
    top: 0;
  }
</style>
