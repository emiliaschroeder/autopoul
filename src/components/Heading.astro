---
// Astro.props: kun style
const { style = "h2", stylingclasses = "" } = Astro.props;

// style bestemmer både HTML-tag og Tailwind-classes
const sizeClasses = {
  hero: "text-[130px] md:text-[300px] font-display uppercase",
  h1: "text-[80px] md:text-[200px] font-display uppercase leading-[185px]",
  h2: "text-[30px] md:text-[60px] font-sans uppercase",
  h3: "text-[24px] md:text-[40px] font-script",
  h4: "text-[20px] md:text-[30px] font-sans",
  display: "text-[60px] md:text-[130px] font-script",
  cardSmall:
    "text-[24px] md:text-[30px] font-display uppercase [font-variation-settings:'wdth'_79]",
  cardLarge:
    "text-[60px] md:text-[70px] font-display uppercase [font-variation-settings:'wdth'_75]",
};

const Htmlheading = style;
---

<Htmlheading class:list={[sizeClasses[style], stylingclasses]}>
  <slot />
</Htmlheading>
